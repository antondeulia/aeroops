<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <material name="aeroops_dark">
        <color rgba="0.05 0.05 0.05 1.0" />
    </material>

    <material name="aeroops_gray">
        <color rgba="0.35 0.35 0.35 1.0" />
    </material>

    <material name="aeroops_blue">
        <color rgba="0.0 0.25 0.8 1.0" />
    </material>

    <material name="aeroops_sensor">
        <color rgba="0.02 0.02 0.02 1.0" />
    </material>

</robot>